{
  "name": "toeic-center-finder",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3000",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1 --port 3000",
    "typecheck": "tsc --noEmit",
    "test:centers": "node --test tests/update-toeic-centers.test.mjs",
    "centers:refresh": "node scripts/update-toeic-centers.mjs",
    "centers:check": "node scripts/update-toeic-centers.mjs --check",
    "dev:e2e": "node scripts/dev-with-mock.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:live": "PLAYWRIGHT_LIVE_SMOKE=1 playwright test tests/live.smoke.spec.ts"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "leaflet": "^1.9.4",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "styled-components": "^6.1.16"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.0",
    "@types/leaflet": "^1.9.17",
    "@types/node": "^22.10.1",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "typescript": "^5.7.2"
  }
}
